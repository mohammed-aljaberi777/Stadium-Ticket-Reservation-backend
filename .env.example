# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# --- Application ---
APP_NAME=Stadium Ticket Reservation
ENVIRONMENT=development
DEBUG=true

# --- PostgreSQL ---
# Host is the docker-compose service name ("db") when running in Docker,
# or "localhost" when running the app directly on your machine.
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ticketing
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Security / JWT ---
# Generate a strong random secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=replace_me_with_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
